# Optional compile-time defaults baked into the firmware via `option_env!`
# in src/settings.rs (`Settings::defaults_from_env`).
#
# For production use, leave this file absent / these variables unset and
# provision the device at first boot via the onboarding captive portal
# (the device comes up as an AP when no valid NVS record is present).
#
# These defaults are only consulted as a fallback when NVS is unprovisioned,
# and exist mainly to speed up dev iteration. Source this file before
# `cargo build` / `./build-ota.sh` if you want them baked in:
#
#   source network.env && ./build-ota.sh

export CONWAY_SSID="YourWiFi"              # SSID to connect to
export CONWAY_PASSWORD="your-wifi-password" # WPA2 passphrase
export CONWAY_HOST="192.168.1.10"          # Conway server IPv4 (leave unset for standalone)
